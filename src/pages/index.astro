---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

// Ambil semua apps dari content collection
const allApps = await getCollection("apps");

// Urutkan: yang statusnya "Tersedia" tampil duluan
const statusOrder = ["Tersedia", "Beta", "Close Testing", "Segera Hadir"];
const apps = allApps.sort(
  (a, b) =>
    statusOrder.indexOf(a.data.status) - statusOrder.indexOf(b.data.status)
);

// Helper: map status → Badge variant
function badgeVariant(status: string) {
  switch (status) {
    case "Tersedia":
      return "success";
    case "Beta":
    case "Close Testing":
      return "default";
    default:
      return "secondary";
  }
}

const stack = [
  { name: "Kotlin", icon: "🟣", desc: "Bahasa utama Android" },
  { name: "Jetpack Compose", icon: "⚡", desc: "UI toolkit modern" },
  { name: "Room / SQLite", icon: "🗄️", desc: "Database lokal" },
  { name: "Hilt / DI", icon: "🧩", desc: "Dependency injection" },
  { name: "Coroutines / Flow", icon: "🔄", desc: "Async & reaktif" },
  { name: "Material 3", icon: "🎨", desc: "Desain sistem Google" },
  { name: "Tauri + React", icon: "🖥️", desc: "Desktop (segera hadir)" },
  { name: "Astro", icon: "🚀", desc: "Website & landing page" },
];
---

<BaseLayout
  title="Beranda"
  description="SarilabStudio — Kami merancang & mengembangkan aplikasi mobile Android berkualitas tinggi menggunakan Jetpack Compose, dari ide hingga produksi."
>
  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background: gelap di dark mode, putih bersih di light mode -->
    <div class="absolute inset-0 bg-white dark:bg-linear-to-br dark:from-navy-800 dark:via-[#16233a] dark:to-navy-800"></div>
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 dot-grid opacity-20 dark:opacity-40"></div>
    <!-- Radial glow: biru lembut di light, lebih terang di dark -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-150 h-150 bg-blue-500/10 dark:bg-blue-600/20 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-16">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 mb-8 animate-on-scroll">
          <span class="w-2 h-2 rounded-full bg-blue-500 dark:bg-blue-400 animate-pulse"></span>
          <span class="text-blue-600 dark:text-blue-300 text-xs font-mono tracking-widest uppercase">
            Mobile Developer · Android · Bali
          </span>
        </div>

        <!-- Headline -->
        <h1 class="font-heading font-extrabold text-5xl md:text-7xl leading-[1.05] text-slate-900 dark:text-white mb-6 animate-on-scroll">
          Membangun Solusi Digital
          <br />
          <span class="text-gradient-blue">yang Berdampak</span>
        </h1>

        <!-- Sub -->
        <p class="text-slate-500 dark:text-slate-300 text-lg md:text-xl leading-relaxed max-w-xl mb-10 animate-on-scroll font-body">
          Kami merancang & mengembangkan aplikasi mobile Android berkualitas tinggi menggunakan Jetpack Compose — dari ide hingga produksi.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 animate-on-scroll">
          <a
            href="/apps"
            class="px-7 py-3.5 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-500 transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.35)] font-heading"
          >
            Lihat Aplikasi
          </a>
          <a
            href="mailto:hello@sarilabstudio.com"
            class="px-7 py-3.5 text-sm font-semibold text-slate-700 dark:text-slate-200 rounded-xl border border-slate-300 dark:border-white/15 hover:border-blue-400 dark:hover:border-blue-500/40 hover:text-blue-600 dark:hover:text-white hover:bg-blue-50 dark:hover:bg-white/5 transition-all duration-200 font-heading"
          >
            Hubungi Kami
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30 dark:opacity-40">
      <div class="w-px h-12 bg-linear-to-b from-transparent to-blue-500 dark:to-blue-400"></div>
      <div class="w-1 h-1 rounded-full bg-blue-500 dark:bg-blue-400"></div>
    </div>
  </section>

  <!-- ── Apps ──────────────────────────────────────── -->
  <section class="py-24 bg-white dark:bg-navy-900/80 transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-14 animate-on-scroll">
        <p class="section-label">Produk</p>
        <h2 class="font-heading font-extrabold text-4xl md:text-5xl text-slate-900 dark:text-white mb-4">
          Aplikasi Kami
        </h2>
        <p class="text-slate-500 dark:text-slate-400 text-lg max-w-lg font-body">
          Aplikasi yang telah kami rilis dan sedang dalam pengembangan.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {apps.map((app, i) => (
          <a
            href={`/apps/${app.id}`}
            class="group rounded-2xl border border-slate-200 dark:border-white/8 bg-slate-50/80 dark:bg-navy-800/60 backdrop-blur-sm hover:border-blue-300 dark:hover:border-blue-500/30 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:bg-navy-700/60 transition-all duration-300 p-7 flex flex-col gap-5 animate-on-scroll"
            style={`transition-delay:${i * 60}ms`}
          >
            <div class="flex items-start justify-between">
              <!-- Icon dari field image() di schema -->
              <div class="w-12 h-12 rounded-2xl overflow-hidden border border-blue-200/50 dark:border-blue-500/20 flex items-center justify-center bg-linear-to-br from-blue-50 to-blue-100 dark:from-blue-500/15 dark:to-blue-600/5">
                <img
                  src={app.data.icon.src}
                  alt={app.data.name}
                  width={48}
                  height={48}
                  class="object-cover w-full h-full"
                />
              </div>

              <Badge variant={badgeVariant(app.data.status)}>
                {app.data.status}
              </Badge>
            </div>

            <div>
              <h3 class="font-heading font-bold text-slate-900 dark:text-slate-100 text-xl mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {app.data.name}
              </h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed font-body">
                {app.data.tagline}
              </p>
            </div>

            <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
              {(app.data.tags ?? app.data.techStack.slice(0, 3)).map((tag) => (
                <Badge variant="outline">{tag}</Badge>
              ))}
            </div>
          </a>
        ))}
      </div>

      <!-- Link ke halaman apps -->
      <div class="mt-10 text-center animate-on-scroll">
        <a
          href="/apps"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold font-heading text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-500/30 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-all duration-200"
        >
          Lihat Semua Aplikasi
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Tech Stack ─────────────────────────────────── -->
  <section class="py-24 bg-slate-50 dark:bg-navy-800/50 transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-14 animate-on-scroll">
        <p class="section-label">Tech Stack</p>
        <h2 class="font-heading font-extrabold text-4xl md:text-5xl text-slate-900 dark:text-white mb-4">
          Teknologi Unggulan
        </h2>
        <p class="text-slate-500 dark:text-slate-400 text-lg max-w-lg font-body">
          Kami membangun dengan teknologi modern yang terbukti andal.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stack.map((item, i) => (
          <div
            class="p-5 rounded-2xl border border-slate-200 dark:border-white/8 bg-white dark:bg-navy-800/60 hover:border-blue-300 dark:hover:border-blue-500/30 hover:shadow-md transition-all duration-300 animate-on-scroll"
            style={`transition-delay:${i * 50}ms`}
          >
            <span class="text-3xl block mb-3">{item.icon}</span>
            <p class="font-heading font-bold text-slate-900 dark:text-slate-100 text-sm mb-1">{item.name}</p>
            <p class="text-slate-500 dark:text-slate-500 text-xs font-body">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ─────────────────────────────────── -->
  <section class="py-24 bg-white dark:bg-navy-900 transition-colors duration-300">
    <div class="max-w-4xl mx-auto px-6 text-center animate-on-scroll">
      <div class="relative rounded-3xl overflow-hidden bg-linear-to-br from-blue-600 to-navy-700 p-12 md:p-16 shadow-2xl shadow-blue-500/20">
        <div class="absolute inset-0 dot-grid opacity-20"></div>
        <div class="relative z-10">
          <h2 class="font-heading font-extrabold text-3xl md:text-5xl text-white mb-4">
            Ada proyek di pikiran?
          </h2>
          <p class="text-blue-100 text-lg mb-8 font-body max-w-lg mx-auto">
            Mari diskusikan bagaimana kami bisa membantu mewujudkan ide Anda menjadi produk nyata.
          </p>
          <a
            href="mailto:hello@sarilabstudio.com"
            class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold text-blue-700 bg-white rounded-xl hover:bg-blue-50 transition-all duration-200 shadow-lg font-heading"
          >
            Hubungi Kami
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>