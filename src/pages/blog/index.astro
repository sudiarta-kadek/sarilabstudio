---
// src/pages/blog/index.astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";

// Ambil semua post, filter draft, urutkan terbaru
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });

const tagVariant = (tag: string) => {
  if (tag === "Android") return "success";
  if (tag === "Kotlin") return "info";
  if (tag === "Case Study") return "default";
  return "secondary";
};
---

<BaseLayout
  title="Blog"
  description="Pemikiran tentang pengembangan Android, Kotlin, Jetpack Compose, dan pengalaman membangun produk digital dari Bali."
>
  <section class="pt-32 pb-24 max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="mb-16 animate-on-scroll">
      <p class="section-label">Tulisan</p>
      <h1 class="font-heading text-5xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight mb-5">
        Catatan &{" "}
        <span class="text-gradient-blue italic">Artikel.</span>
      </h1>
      <p class="text-slate-500 dark:text-slate-400 text-lg max-w-xl leading-relaxed font-body">
        Pemikiran tentang pengembangan Android, Kotlin, Jetpack Compose, dan pengalaman membangun produk digital dari Bali.
      </p>
    </div>

    <!-- Post list -->
    <div class="flex flex-col gap-5">
      {posts.map((post: CollectionEntry<"blog">, i: number) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-2xl border border-slate-200 dark:border-white/8 bg-white/80 dark:bg-navy-800/60 backdrop-blur-sm hover:border-blue-300 dark:hover:border-blue-500/30 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:bg-navy-700/60 transition-all duration-300 p-7 flex flex-col md:flex-row md:items-center gap-5 animate-on-scroll"
            style={`transition-delay:${i * 60}ms`}
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                <Badge variant={tagVariant(post.data.tags?.[0] ?? "Artikel")}>{post.data.tags?.[0] ?? "Artikel"}</Badge>
                <span class="font-mono text-xs text-slate-400 dark:text-slate-600">
                  {formatDate(post.data.pubDate)}
                </span>
                {post.data.readTime && (
                  <>
                    <span class="text-slate-300 dark:text-slate-700">·</span>
                    <span class="font-mono text-xs text-slate-400 dark:text-slate-600">
                      {post.data.readTime} menit baca
                    </span>
                  </>
                )}
              </div>
              <h2 class="font-heading font-bold text-slate-900 dark:text-slate-100 text-xl mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed font-body">
                {post.data.description}
              </p>
            </div>
            <div class="shrink-0 flex items-center gap-2 text-sm font-medium text-blue-600 dark:text-blue-400 group-hover:gap-3 transition-all font-heading">
              Baca Selengkapnya
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          </a>
          )
        )
      }
    </div>
  </section>
</BaseLayout>